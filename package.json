{
  "name": "dev",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.24.3",
      "postcss": ">=8.5.10"
    }
  },
  "scripts": {
    "assets:capture-deployments": "tsx scripts/capture-deployment-previews.ts",
    "assets:upload-cv": "tsx scripts/upload-cv.ts",
    "dev": "next dev",
    "build": "tsx scripts/vercel-db-setup.ts && next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed -- --if-empty",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint app src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --skipLibCheck --module ESNext --moduleResolution Bundler --target ES2022 --lib ES2022,DOM --types node scripts/*.ts *.config.ts",
    "start": "next start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@neondatabase/serverless": "^1.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^4.10.1",
    "react-type-animation": "^3.1.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@next/env": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
